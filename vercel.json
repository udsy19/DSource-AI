{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "frontend": {
      "root": ".",
      "framework": "nextjs",
      "bindings": [
        {
          "type": "service",
          "service": "cad-export",
          "format": "url",
          "env": "CAD_EXPORT_URL"
        }
      ]
    },
    "cad-export": {
      "root": "services/cad-export",
      "framework": "fastapi",
      "entrypoint": "main:app"
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": { "service": "frontend" } }]
}
