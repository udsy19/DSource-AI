# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored — never commit real keys.

# Supabase — find these in your Supabase dashboard under Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Google Gemini — create a key at https://aistudio.google.com/apikey
# Server-side only; used by /api/generate-image, /api/reverse-search and the
# Material Finder's product triage + seller verification.
GOOGLE_GENAI_API_KEY=your-gemini-api-key

# Replicate — image generation + CLIP embeddings for the AI Visualizer
REPLICATE_API_TOKEN=your-replicate-token

# Material bank catalog API (optional). When set, the visualizer's reverse
# material search and the marketplace browse the live catalog.
MATERIAL_BANK_API_URL=

# Supabase service-role key — Project Settings → API → service_role (secret).
# SERVER-ONLY. Bypasses Row Level Security. Used by the admin role-granting
# endpoint (/api/admin/grant-role) and scripts/backfill-embeddings.mjs.
# NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Comma-separated emails allowed to grant roles via /api/admin/grant-role.
ADMIN_EMAILS=admin@example.com

# Public site URL — used for auth redirect construction and SEO metadata.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ---------------------------------------------------------------------------
# Material Finder (/material-finder/find) — seller discovery providers.
#
# Every one of these is OPTIONAL and independently degradable: with none set,
# the finder still runs against the DSource catalog alone and says plainly
# which sources it didn't search. Nothing 500s when a key is missing.
#
# Budgeting note: independent benchmarks put competent scraping vendors at
# 61-67% success on retail, so assume ~1.5x every list price below per page
# you actually get. Measure against your own URL mix before committing.
# ---------------------------------------------------------------------------

# SerpAPI — Google Lens (image -> sellers). The broadest image reach available.
# ⚠️ LEGAL: SerpAPI is the defendant in Google v. SerpApi (N.D. Cal., DMCA
# §1201) and a co-defendant in Reddit v. Perplexity et al., which attacks the
# "we don't scrape retailers, we just use a SERP API" posture directly. Their
# advertised "U.S. Legal Shield" is marketing, not an indemnity. The provider
# is isolated in src/utils/finder/providers/lens.js so it can be removed
# outright — unset this key and the pipeline drops it cleanly.
# https://serpapi.com/pricing  ($9-25 / 1k searches)
# SERPAPI_KEY=

# ShopSavvy — identifier (GTIN/MPN/ASIN) -> offers across retailers.
# The closest thing to a real "barcode -> every seller" endpoint that exists.
# ⚠️ Coverage ("70,000+ retailers") is the vendor's own unverified claim and is
# weakest exactly where DSource is strongest (furniture). Trial before relying.
# ~$0.06 per offers lookup (3 credits). https://shopsavvy.com/data
# SHOPSAVVY_API_KEY=

# Shopify Global Catalog MCP — free, keyless, multi-merchant, takes an image.
# 🚨 Its terms forbid caching results or images — see the migration comment in
# supabase/migrations/20260720_material_finder.sql before adding any cache.
# ⚠️ The wire format in providers/shopify.js is UNVERIFIED against a live call,
# which is why this is off unless you set the URL explicitly. Confirm against
# https://shopify.dev/docs/agents/catalog/mcp first.
# SHOPIFY_CATALOG_MCP_URL=

# Unblocker for the URL path. Retail sites block plain requests (Best Buy, B&H,
# Home Depot, Walmart, Chewy, Argos all do), so without one of these the URL
# path only works on unprotected merchants — it degrades honestly and tells the
# user to try a photo instead. Both bill per SUCCESS, so failed attempts are
# free and a fallback chain costs nothing.
# Oxylabs: $0.25-0.50 / 1k  https://oxylabs.io/products/scraper-api/web/pricing
# OXYLABS_USER=
# OXYLABS_PASS=
# Zyte: from $0.13/1k HTTP, ~$1.00/1k browser-rendered, tiered by target.
# ZYTE_API_KEY=

# CAD professional export microservice (services/cad-export) — optional.
# When set, /api/cad-convert returns an ezdxf-authored DXF (blocks, hatching,
# dimensions, title block) and DWG when the ODA converter is installed.
# CAD_EXPORT_URL=http://localhost:8100
# Shared secret for the microservice (set the same value on both sides).
# CAD_EXPORT_TOKEN=

# Dev-only: skip login for local testing (hard-disabled in production
# builds regardless of this value). Never set in deployed environments.
# DEV_AUTH_BYPASS=true
