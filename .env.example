# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored — never commit real keys.

# Supabase — find these in your Supabase dashboard under Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Google Gemini — create a key at https://aistudio.google.com/apikey
# Server-side only; used by /api/analyze-image and /api/generate-image
GOOGLE_GENAI_API_KEY=your-gemini-api-key

# Replicate — image generation + CLIP embeddings for the AI Visualizer
REPLICATE_API_TOKEN=your-replicate-token

# Material bank catalog API (optional). When set, the visualizer's reverse
# material search matches against this catalog instead of the per-user
# Supabase one.
MATERIAL_BANK_API_URL=

# Service role key (SECRET, server/scripts only) — used by
# scripts/backfill-embeddings.mjs for the Supabase fallback search path.
SUPABASE_SERVICE_ROLE_KEY=
